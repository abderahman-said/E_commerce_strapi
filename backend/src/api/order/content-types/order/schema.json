{
  "kind": "collectionType",
  "collectionName": "orders",
  "info": {
    "singularName": "order",
    "pluralName": "orders",
    "displayName": "Order",
    "description": "Customer orders"
  },
  "options": {
    "draftAndPublish": false
  },
  "attributes": {
    "status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "processing",
        "shipped",
        "delivered",
        "cancelled"
      ],
      "default": "pending"
    },
    "total": {
      "type": "decimal",
      "required": true
    },
    "items": {
      "type": "json",
      "required": true
    },
    "shippingAddress": {
      "type": "json",
      "required": true
    },
    "payment_id": {
      "type": "string"
    },
    "payment_status": {
      "type": "enumeration",
      "enum": [
        "unpaid",
        "paid",
        "failed"
      ],
      "default": "unpaid"
    },
    "payment_method": {
      "type": "string"
    }
  }
}
